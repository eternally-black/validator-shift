{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": { "@validator-shift/*": ["packages/*/src"] }
  }
}
